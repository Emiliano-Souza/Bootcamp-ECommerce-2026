<?php
/** @var \Bootcamp\AemContent\Block\Banner $block */
$banner = $block->getBanner();

if (!$block->canRender()) {
    return;
}

$hasImage = !empty($banner['image_url']);
$style = $hasImage
    ? 'background-image: linear-gradient(135deg, rgba(27, 38, 59, 0.92), rgba(65, 90, 119, 0.82)), url('
        . $block->escapeUrl($banner['image_url'])
        . '); background-size: cover; background-position: center;'
    : 'background: linear-gradient(135deg, #1b263b, #415a77);';
?>
<section class="bootcamp-aem-banner"
         style="<?= $block->escapeHtmlAttr($style) ?> margin: 0 0 24px; border-radius: 16px; color: #fff; overflow: hidden;">
    <div style="padding: 32px 28px;">
        <?php if (!empty($banner['eyebrow'])): ?>
            <div style="font-size: 12px; font-weight: 700; letter-spacing: 0.12em; margin-bottom: 12px; opacity: 0.88; text-transform: uppercase;">
                <?= $block->escapeHtml($banner['eyebrow']) ?>
            </div>
        <?php endif; ?>

        <h2 style="margin: 0 0 12px; font-size: 32px; line-height: 1.15;">
            <?= $block->escapeHtml($banner['title']) ?>
        </h2>

        <?php if (!empty($banner['description'])): ?>
            <p style="max-width: 720px; margin: 0 0 20px; font-size: 16px; line-height: 1.6;">
                <?= $block->escapeHtml($banner['description']) ?>
            </p>
        <?php endif; ?>

        <?php if (!empty($banner['cta_label'])): ?>
            <a href="<?= $block->escapeUrl($banner['cta_url']) ?>"
               style="display: inline-block; padding: 12px 18px; background: #e0fbfc; color: #0d1b2a; border-radius: 999px; font-weight: 700; text-decoration: none;">
                <?= $block->escapeHtml($banner['cta_label']) ?>
            </a>
        <?php endif; ?>
    </div>
</section>
