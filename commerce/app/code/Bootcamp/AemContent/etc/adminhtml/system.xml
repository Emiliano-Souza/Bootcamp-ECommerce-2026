<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <section id="bootcamp_aem" translate="label" sortOrder="900" showInDefault="1" showInWebsite="1" showInStore="1">
            <label>Bootcamp AEM</label>
            <tab>general</tab>
            <resource>Magento_Config::config</resource>
            <group id="banner" translate="label" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Homepage Banner</label>
                <field id="enabled" translate="label" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable Banner</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="endpoint" translate="label comment" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>AEM JSON Endpoint</label>
                    <comment>Use a published AEM endpoint that returns banner data as JSON.</comment>
                </field>
                <field id="request_timeout" translate="label comment" type="text" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Request Timeout (seconds)</label>
                    <comment>Recommended: 3 to 5 seconds.</comment>
                    <validate>validate-number validate-greater-than-zero</validate>
                </field>
                <field id="title" translate="label" type="text" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Fallback Title</label>
                </field>
                <field id="description" translate="label" type="textarea" sortOrder="50" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Fallback Description</label>
                </field>
                <field id="cta_label" translate="label" type="text" sortOrder="60" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Fallback CTA Label</label>
                </field>
                <field id="cta_url" translate="label" type="text" sortOrder="70" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Fallback CTA URL</label>
                </field>
            </group>
        </section>
    </system>
</config>
